<resources>
    <!-- Base Dark Glassmorphism Theme -->
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/colorPrimaryDark</item>
        <item name="android:colorBackground">@color/colorPrimaryDark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        
        <!-- Glassmorphism Window Settings -->
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        
        <!-- Material Component Overrides -->
        <item name="materialButtonStyle">@style/GlassButton</item>
        <item name="materialCardViewStyle">@style/GlassCard</item>
        <item name="android:textViewStyle">@style/GlassText</item>
    </style>
    
    <!-- Glass Button Style -->
    <style name="GlassButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/glass_button_background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Glass Card Style -->
    <style name="GlassCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_border</item>
    </style>
    
    <!-- Glass Text Style -->
    <style name="GlassText" parent="android:Widget.TextView">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <!-- Glass Title Style -->
    <style name="GlassTitle" parent="GlassText">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Glass Subtitle Style -->
    <style name="GlassSubtitle" parent="GlassText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>